{
  "name": "openply",
  "version": "0.3.0",
  "description": "openPly — free, local-first AI coding assistant",
  "bin": {
    "openply": "./dist/cli/index.js"
  },
  "main": "./dist/cli/index.js",
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/cli/index.ts --format cjs --outDir dist/cli",
    "dev": "tsup src/cli/index.ts --format cjs --outDir dist/cli --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openply/core": "*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
