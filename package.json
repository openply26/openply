{
  "name": "openply",
  "version": "0.1.0",
  "description": "openPly — free, local-first AI coding assistant. Your code never leaves your machine.",
  "bin": {
    "openply": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/cli/index.ts src/index.ts --format cjs --outDir dist --clean",
    "build:cli": "tsup src/cli/index.ts --format cjs --outDir dist/cli",
    "build:lib": "tsup src/index.ts --format cjs,esm --dts --outDir dist",
    "dev": "tsup src/cli/index.ts --format cjs --outDir dist/cli --watch",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai", "coding", "assistant", "cli", "open-source",
    "free", "code-generation", "developer-tools",
    "multi-agent", "local-first", "privacy"
  ],
  "license": "MIT",
  "author": "openPly",
  "repository": {
    "type": "git",
    "url": "https://github.com/openply26/openply"
  },
  "bugs": {
    "url": "https://github.com/openply26/openply/issues"
  },
  "homepage": "https://openply.pages.dev",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "openai": "^4.40.0",
    "better-sqlite3": "^11.0.0",
    "diff": "^5.2.0",
    "glob": "^10.3.0",
    "ignore": "^5.3.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/diff": "^5.2.0",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
